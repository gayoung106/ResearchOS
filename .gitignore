# Python 가상환경
.venv/
venv/
env/

# Python 캐시
__pycache__/
*.py[cod]
*$py.class
.pytest_cache/
.mypy_cache/
.ruff_cache/
.coverage
htmlcov/

# Jupyter
.ipynb_checkpoints/

# IDE
.vscode/
.idea/

# 운영체제
.DS_Store
Thumbs.db
desktop.ini

# 환경변수와 비밀정보
.env
.env.*
!.env.example

# 원자료
rawdata/*
!rawdata/.gitkeep

# 설문지·코드북
questionnaire/*
!questionnaire/.gitkeep

# 분석 결과
result/*
!result/.gitkeep
!result/logs/
result/logs/*
!result/logs/.gitkeep

# 논문 초안
manuscript/*
!manuscript/.gitkeep

# 임시 파일
*.tmp
*.temp
*.bak
*.log
~$*